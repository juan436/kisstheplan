# ============================================================
# KissthePlan Frontend — Variables de entorno (DEV LOCAL)
# ============================================================
# COPIA este archivo a ".env.local" para desarrollo.
# NUNCA hagas commit de .env.local
# ============================================================

# --- Backend (URL local del servidor NestJS) ---
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# --- Activar API real (true) o mock (false) ---
NEXT_PUBLIC_USE_REAL_API=true

# --- URL pública del frontend (usada para generar links de la web de boda) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
