# ============================================================
# KissthePlan Frontend — Variables de entorno (PRODUCCIÓN)
# ============================================================
# COPIA este archivo a ".env.production.local" en el servidor.
# NUNCA hagas commit de archivos .env con valores reales.
# ============================================================

# --- Backend (URL local del servidor NestJS) ---
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# --- Activar API real ---
NEXT_PUBLIC_USE_REAL_API=true

# --- URL pública del frontend (usada para generar links de la web de boda) ---
NEXT_PUBLIC_SITE_URL=https://kisstheplan.com

# --- Traefik (dominio público del frontend) ---
FRONTEND_DOMAIN=kisstheplan.com
