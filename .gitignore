# ============================================================
# KissthePlan — Frontend .gitignore
# ============================================================

# --- Docker (se gestiona fuera del repo) ---
docker-compose.yml
.dockerignore

# --- Dependencias ---
node_modules/

# --- Build de Next.js (se genera en CI/Docker) ---
.next/
out/

# --- Variables de entorno (NUNCA al repo) ---
.env
.env.*
!.env.example

# --- pnpm ---
.pnpm-store/
.pnpm-debug.log*

# --- Logs ---
*.log
logs/

# --- TypeScript incremental ---
*.tsbuildinfo
next-env.d.ts

# --- OS / Editores ---
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- Certificados / claves ---
*.pem
*.key
*.crt
